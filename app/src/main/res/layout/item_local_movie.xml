<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="@drawable/bg_card"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="5dp"
    android:gravity="center_vertical">

    <!-- Thumbnail -->
    <FrameLayout android:layout_width="80dp" android:layout_height="80dp">
        <ImageView android:id="@+id/imgThumbnail" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:background="@color/bg_elevated" android:contentDescription="@null"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:background="#55000000">
            <ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@android:drawable/ic_media_play" android:contentDescription="@null"/>
        </LinearLayout>
        <TextView android:id="@+id/badgeBlur" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|start" android:layout_margin="4dp" android:paddingHorizontal="5dp" android:paddingVertical="2dp" android:text="BLUR" android:textColor="@color/white" android:textSize="8sp" android:textStyle="bold" android:background="@drawable/bg_badge_red" android:visibility="gone"/>
    </FrameLayout>

    <!-- Info -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
        <TextView android:id="@+id/tvFileName" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" android:maxLines="2" android:ellipsize="end" android:layout_marginBottom="4dp"/>
        <TextView android:id="@+id/tvFileInfo" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/text_muted" android:textSize="11sp" android:layout_marginBottom="10dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LOCAL" android:textColor="@color/white" android:textSize="9sp" android:textStyle="bold" android:paddingHorizontal="8dp" android:paddingVertical="3dp" android:background="@drawable/bg_badge_green"/>
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchBlur"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blur"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:checked="true"
                app:thumbTint="@color/lumio_blue"
                app:trackTint="@color/bg_elevated"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Options -->
    <ImageView android:id="@+id/btnMore" android:layout_width="30dp" android:layout_height="30dp" android:src="@android:drawable/ic_menu_more" android:tint="@color/text_muted" android:contentDescription="Options" android:padding="4dp"/>

</LinearLayout>
