<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp"
    android:background="@drawable/bg_card"
    android:layout_marginHorizontal="16dp" android:layout_marginVertical="5dp"
    android:gravity="center_vertical">

    <ImageView android:id="@+id/imgPoster" android:layout_width="70dp"
        android:layout_height="100dp" android:scaleType="centerCrop"
        android:background="@color/bg_elevated" android:contentDescription="@null"/>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">

        <TextView android:id="@+id/tvTitle" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/text_primary"
            android:textSize="14sp" android:textStyle="bold" android:maxLines="2"
            android:ellipsize="end" android:layout_marginBottom="4dp"/>

        <TextView android:id="@+id/tvYear" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/text_muted"
            android:textSize="12sp" android:layout_marginBottom="6dp"/>

        <TextView android:id="@+id/tvScore" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="@color/star_color"
            android:textSize="12sp" android:textStyle="bold"/>
    </LinearLayout>

    <ImageView android:id="@+id/btnRemove" android:layout_width="32dp"
        android:layout_height="32dp" android:src="@android:drawable/ic_menu_delete"
        android:tint="@color/text_muted" android:contentDescription="Retirer"
        android:padding="4dp"/>

</LinearLayout>
