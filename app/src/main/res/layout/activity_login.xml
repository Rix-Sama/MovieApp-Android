<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="28dp"
        android:paddingTop="72dp"
        android:paddingBottom="40dp">

        <!-- Star icon -->
        <View
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_avatar"
            android:layout_marginBottom="16dp" />

        <!-- Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LUMIO"
            android:textColor="@color/text_primary"
            android:textSize="38sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Le cinéma en famille"
            android:textColor="@color/text_hint"
            android:textSize="13sp"
            android:letterSpacing="0.05"
            android:layout_marginBottom="52dp"/>

        <!-- Email -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Adresse email"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="16dp"
            android:inputType="textEmailAddress"
            android:hint="exemple@email.com"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"/>

        <!-- Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mot de passe"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="16dp"
            android:inputType="textPassword"
            android:hint="••••••••"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginBottom="28dp"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:indeterminateTint="@color/lumio_blue"
            android:visibility="gone"/>

        <!-- Login button -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_button_primary"
            android:text="SE CONNECTER"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:stateListAnimator="@null"/>

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginVertical="24dp">
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/divider"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingHorizontal="14dp" android:text="ou" android:textColor="@color/text_muted" android:textSize="13sp"/>
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/divider"/>
        </LinearLayout>

        <!-- Register -->
        <Button
            android:id="@+id/btnGoRegister"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Créer un compte"
            android:textColor="@color/lumio_blue"
            android:textSize="14sp"
            android:stateListAnimator="@null"/>

        <TextView
            android:id="@+id/tvRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:padding="8dp"
            android:text="Mot de passe oublié ?"
            android:textColor="@color/text_hint"
            android:textSize="13sp"/>

    </LinearLayout>
</ScrollView>
