<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="14dp"
    android:background="@drawable/bg_card"
    android:layout_marginHorizontal="16dp" android:layout_marginVertical="5dp"
    android:gravity="center_vertical">

    <!-- Avatar -->
    <TextView android:id="@+id/tvChildAvatar" android:layout_width="44dp"
        android:layout_height="44dp" android:background="@drawable/bg_avatar"
        android:gravity="center" android:textColor="@color/white"
        android:textSize="16sp" android:textStyle="bold"/>

    <!-- Info -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">

        <TextView android:id="@+id/tvChildName" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/text_primary"
            android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="2dp"/>

        <TextView android:id="@+id/tvChildEmail" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/text_muted"
            android:textSize="11sp" android:layout_marginBottom="8dp"/>

        <!-- Restriction slider row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Restriction :" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:layout_marginEnd="6dp"/>

            <SeekBar android:id="@+id/seekRestriction" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:max="2" android:progress="0"
                android:progressTint="@color/lumio_blue"
                android:thumbTint="@color/lumio_blue"/>

            <TextView android:id="@+id/tvRestrictionLabel"
                android:layout_width="48dp" android:layout_height="wrap_content"
                android:text="Strict" android:textColor="@color/lumio_blue"
                android:textSize="10sp" android:textStyle="bold"
                android:layout_marginStart="6dp" android:gravity="end"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Delete -->
    <ImageView android:id="@+id/btnDeleteChild" android:layout_width="32dp"
        android:layout_height="32dp" android:src="@android:drawable/ic_menu_delete"
        android:tint="@color/text_muted" android:contentDescription="Supprimer"
        android:padding="4dp"/>

</LinearLayout>
