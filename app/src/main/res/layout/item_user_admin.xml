<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp"
    android:background="@drawable/bg_card"
    android:layout_marginHorizontal="16dp" android:layout_marginVertical="4dp"
    android:gravity="center_vertical">

    <TextView android:id="@+id/tvUserAvatar" android:layout_width="40dp"
        android:layout_height="40dp" android:background="@drawable/bg_avatar"
        android:gravity="center" android:textColor="@color/white"
        android:textSize="14sp" android:textStyle="bold"/>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:paddingStart="10dp">
        <TextView android:id="@+id/tvUserName" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/text_primary"
            android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="2dp"/>
        <TextView android:id="@+id/tvUserEmail" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/text_muted"
            android:textSize="11sp"/>
    </LinearLayout>

    <TextView android:id="@+id/tvUserRole" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textColor="@color/white"
        android:textSize="9sp" android:textStyle="bold"
        android:paddingHorizontal="8dp" android:paddingVertical="3dp"
        android:background="@drawable/bg_badge_red" android:layout_marginEnd="8dp"/>

    <ImageView android:id="@+id/btnToggleUser" android:layout_width="28dp"
        android:layout_height="28dp" android:src="@android:drawable/ic_menu_manage"
        android:tint="@color/text_muted" android:contentDescription="Toggle"
        android:padding="3dp"/>

</LinearLayout>
