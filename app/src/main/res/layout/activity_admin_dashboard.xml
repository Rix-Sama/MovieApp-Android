<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="16dp">
        <LinearLayout android:id="@+id/btnBack" android:layout_width="38dp"
            android:layout_height="38dp" android:background="@drawable/bg_back_btn"
            android:gravity="center">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_back" android:contentDescription="@null"/>
        </LinearLayout>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Dashboard Admin"
            android:textColor="@color/text_primary" android:textSize="18sp"
            android:textStyle="bold" android:layout_marginStart="12dp"/>
        <TextView android:id="@+id/tvUserCount" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="@color/text_muted"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Stats row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingHorizontal="16dp"
        android:paddingBottom="12dp">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:background="@drawable/bg_card" android:padding="12dp"
            android:gravity="center" android:layout_marginEnd="6dp">
            <TextView android:id="@+id/tvStatAdmins" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0"
                android:textColor="@color/badge_admin" android:textSize="22sp"
                android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Admins" android:textColor="@color/text_muted" android:textSize="11sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:background="@drawable/bg_card" android:padding="12dp"
            android:gravity="center" android:layout_marginHorizontal="3dp">
            <TextView android:id="@+id/tvStatParents" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0"
                android:textColor="@color/lumio_blue" android:textSize="22sp"
                android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Parents" android:textColor="@color/text_muted" android:textSize="11sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:background="@drawable/bg_card" android:padding="12dp"
            android:gravity="center" android:layout_marginStart="6dp">
            <TextView android:id="@+id/tvStatEnfants" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0"
                android:textColor="@color/badge_enfant" android:textSize="22sp"
                android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Enfants" android:textColor="@color/text_muted" android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Search filter -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="44dp"
        android:orientation="horizontal" android:background="@drawable/bg_input"
        android:layout_marginHorizontal="16dp" android:layout_marginBottom="8dp"
        android:paddingHorizontal="14dp" android:gravity="center_vertical">
        <ImageView android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_search" android:alpha="0.5"
            android:contentDescription="@null" android:layout_marginEnd="8dp"/>
        <EditText android:id="@+id/etFilterUsers" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:background="@null" android:hint="Filtrer les utilisateurs…"
            android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"
            android:textSize="13sp" android:inputType="text"/>
    </LinearLayout>

    <ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_gravity="center_horizontal"
        android:indeterminateTint="@color/lumio_blue" android:visibility="gone"
        android:layout_marginTop="16dp"/>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerUsers"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:clipToPadding="false"
        android:paddingBottom="16dp"/>

</LinearLayout>
