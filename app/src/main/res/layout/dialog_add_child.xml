<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="20dp"
    android:background="@color/bg_surface">

    <EditText android:id="@+id/etChildNom" android:layout_width="match_parent"
        android:layout_height="48dp" android:background="@drawable/bg_input"
        android:paddingHorizontal="14dp" android:hint="Nom"
        android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"
        android:inputType="textPersonName" android:layout_marginBottom="10dp"/>

    <EditText android:id="@+id/etChildPrenom" android:layout_width="match_parent"
        android:layout_height="48dp" android:background="@drawable/bg_input"
        android:paddingHorizontal="14dp" android:hint="Prénom"
        android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"
        android:inputType="textPersonName" android:layout_marginBottom="10dp"/>

    <EditText android:id="@+id/etChildEmail" android:layout_width="match_parent"
        android:layout_height="48dp" android:background="@drawable/bg_input"
        android:paddingHorizontal="14dp" android:hint="Email"
        android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"
        android:inputType="textEmailAddress" android:layout_marginBottom="10dp"/>

    <EditText android:id="@+id/etChildPassword" android:layout_width="match_parent"
        android:layout_height="48dp" android:background="@drawable/bg_input"
        android:paddingHorizontal="14dp" android:hint="Mot de passe (6 min.)"
        android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"
        android:inputType="textPassword"/>

</LinearLayout>
