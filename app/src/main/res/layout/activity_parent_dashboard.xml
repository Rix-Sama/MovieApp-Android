<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="16dp">
        <LinearLayout android:id="@+id/btnBack" android:layout_width="38dp"
            android:layout_height="38dp" android:background="@drawable/bg_back_btn"
            android:gravity="center">
            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_back" android:contentDescription="@null"/>
        </LinearLayout>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Gestion des enfants"
            android:textColor="@color/text_primary" android:textSize="18sp"
            android:textStyle="bold" android:layout_marginStart="12dp"/>
        <Button android:id="@+id/btnAddChild"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:background="@drawable/bg_button_primary"
            android:text="+ Ajouter" android:textColor="@color/white"
            android:textSize="12sp" android:stateListAnimator="@null"/>
    </LinearLayout>

    <!-- Loading -->
    <ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_gravity="center_horizontal"
        android:indeterminateTint="@color/lumio_blue" android:visibility="gone"
        android:layout_marginTop="24dp"/>

    <!-- Children list -->
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerChildren"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:clipToPadding="false"
        android:paddingTop="8dp" android:paddingBottom="16dp"/>

    <!-- Empty state -->
    <LinearLayout android:id="@+id/emptyChildren" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="vertical" android:gravity="center"
        android:padding="32dp" android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="👨‍👧" android:textSize="56sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="16dp" android:text="Aucun compte enfant"
            android:textColor="@color/text_secondary" android:textSize="16sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:text="Appuyez sur + Ajouter"
            android:textColor="@color/text_muted" android:textSize="13sp"/>
    </LinearLayout>

</LinearLayout>
