<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ExoPlayer surface -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="true"
        app:show_timeout="3000"
        app:resize_mode="fit"
        app:controller_layout_id="@layout/exo_custom_controls" />

    <!-- Blur overlay (ML Kit détecte du contenu sensible) -->
    <FrameLayout
        android:id="@+id/blurOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <!-- Blurred snapshot of the frame -->
        <ImageView
            android:id="@+id/blurredFrame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:alpha="0.5"
            android:contentDescription="@null" />

        <!-- Warning panel -->
        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp"
            android:background="@drawable/bg_blur_panel">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔞"
                android:textSize="56sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Contenu sensible détecté"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/tvDetectedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Analyse en cours…"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:textAlignment="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinue"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Continuer quand même"
                android:textColor="#FFFFFF"
                app:strokeColor="#555555"
                app:cornerRadius="24dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- Status bar at top: ML Kit status -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#99000000"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <View
            android:id="@+id/statusDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_dot_green" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="ML Kit: analyse active"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchBlurActive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Blur"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp"
            android:checked="true" />

    </LinearLayout>

</FrameLayout>
